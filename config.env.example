# Ebook Translation Script Configuration
# Copy this file to config.env and fill in your settings

# OpenAI API Configuration
# Single key mode
OPENAI_API_KEY=your_api_key_here

# Multiple keys mode (auto-detected, for rate limit rotation)
# When 429 error occurs, automatically switches to next key
OPENAI_API_KEY_1=your_first_key
OPENAI_API_KEY_2=your_second_key
OPENAI_API_KEY_3=your_third_key

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Multiple Models (comma separated, for rotation)
# OPENAI_MODELS=gpt-4o-mini,gpt-4o,gpt-3.5-turbo

# Target Language
# Supported values: zh, en, ja, ko, fr, de, es, ru, pt, it
# Default: zh (Simplified Chinese)
TRANSLATE_TARGET_LANG=zh

# Translation Settings
TRANSLATE_BATCH_SIZE=50
TRANSLATE_MAX_RETRIES=3
TRANSLATE_RETRY_DELAY=1.0
TRANSLATE_OUTPUT_DIR=~/translated_books
TRANSLATE_MAX_TOKENS=128000

# Format Conversion (requires calibre)
# Supported input formats: .mobi, .azw, .azw3, .pdf
# These formats will be auto-converted to EPUB before translation
# Note: Scanned PDFs (no text layer) will be rejected
